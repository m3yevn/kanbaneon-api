{
  "version": 2,
  "builds": [
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/health", "dest": "/api/health.js" },
    { "src": "/healthz", "dest": "/api/health.js" },
    { "src": "/", "dest": "public/hello.html" },
    { "src": "/public/(.*)", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
